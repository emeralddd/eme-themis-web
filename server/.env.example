# Server port
PORT = 3108

# Path to store Themis uploaded files (absolute or relative to this file, e.g., ./uploads is /server/uploads)
THEMIS_UPLOAD_PATH = ./uploads

# JWT secret token for signing tokens
SECRET_TOKEN = sample_token_please_change_this_to_a_secure_random_value

# Frontend Mode: true for integration with frontend, false for standalone backend
FRONTEND_INTEGRATION = true

# Optional: URL of the frontend application (for CORS, if deployed separately)
FRONTEND_URL = "http://example.com"